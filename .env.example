# ── Apple App Store Connect ───────────────────────────────────
# Get these from https://appstoreconnect.apple.com → Users and Access → Integrations → Keys
APPLE_ISSUER_ID=your-issuer-id-here
APPLE_KEY_ID=your-key-id-here
APPLE_KEY_FILE=./data/keys/AuthKey_YOURKEYID.p8
APPLE_VENDOR_NUMBER=your-vendor-number

# ── Google Play ──────────────────────────────────────────────
# Your Google Play Developer ID (numeric, found in Play Console URL)
GOOGLE_DEVELOPER_ID=your-developer-id
# Path to Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=./data/keys/google-service-account.json
# Optional: comma-separated package names (auto-detected if service account has access)
# GOOGLE_PACKAGES=com.example.app1,com.example.app2
